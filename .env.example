# 医疗影像诊断系统 - Docker Compose 环境变量模板
# 复制此文件为 .env 后，替换下面的占位值。

# ===========================================
# MySQL 数据库配置
# ===========================================
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=<replace-with-db-password>
DB_NAME=medical_imaging_system

# MySQL 容器初始化配置
MYSQL_ROOT_PASSWORD=<replace-with-mysql-root-password>
MYSQL_DATABASE=medical_imaging_system
MYSQL_CHARACTER_SET_SERVER=utf8mb4
MYSQL_COLLATION_SERVER=utf8mb4_unicode_ci

# ===========================================
# Redis 配置
# ===========================================
REDIS_URL=redis://redis:6379/0

# ===========================================
# JWT / 后端配置
# ===========================================
JWT_SECRET_KEY=<replace-with-a-long-random-jwt-secret>
ENVIRONMENT=production
DEBUG=false
PYTHONPATH=/app
FORWARDED_ALLOW_IPS=<replace-with-gpu1-private-ip-or-*>
CORS_ORIGINS=https://xiehe.example.com

# ===========================================
# 端口绑定配置
# ===========================================
# 推荐上线后替换为 CPU2 内网 IP 绑定，例如 10.0.0.12:8080:8080
BACKEND_PORT_BIND=<cpu2-private-ip>:8080:8080
FRONTEND_PORT_BIND=<cpu2-private-ip>:3030:3000
MYSQL_PORT_BIND=127.0.0.1:3306:3306
REDIS_PORT_BIND=127.0.0.1:6380:6379

# ===========================================
# 前端构建配置
# ===========================================
NEXT_PUBLIC_API_URL=https://xiehe.example.com
NEXT_PUBLIC_API_BASE_URL=https://xiehe.example.com
NEXT_PUBLIC_API_VERSION=v1
NEXT_PUBLIC_WEBSOCKET_URL=wss://xiehe.example.com/api/v1/ws/ws
NEXT_PUBLIC_AI_DETECT_URL=https://xiehe.example.com/ai/front/predict
NEXT_PUBLIC_AI_DETECT_KEYPOINTS_URL=https://xiehe.example.com/ai/front/detect_keypoints
NEXT_PUBLIC_AI_DETECT_LATERAL_URL=https://xiehe.example.com/ai/lateral/detect_and_keypoints
NEXT_PUBLIC_AI_DETECT_LATERAL_DETECT_URL=https://xiehe.example.com/ai/lateral/detect

# ===========================================
# 其他应用配置
# ===========================================
DATABASE_URL=mysql+pymysql://root:<replace-with-db-password>@mysql:3306/medical_imaging_system
MAX_UPLOAD_SIZE=104857600
UPLOAD_DIR=/app/uploads
LOG_LEVEL=INFO
LOG_DIR=/app/logs
