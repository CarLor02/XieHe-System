# Runtime and application defaults
ENVIRONMENT=production
DEBUG=false
PYTHONPATH=/app
MAX_UPLOAD_SIZE=104857600
LOG_LEVEL=INFO
LOG_DIR=/app/logs

# Build-time dependency proxy settings.
# Use BUILD_* names so shell-level HTTP_PROXY/http_proxy cannot override compose build args.
# BUILD_HTTP_PROXY=http://host.docker.internal:7890
# BUILD_HTTPS_PROXY=http://host.docker.internal:7890
# BUILD_NO_PROXY=localhost,127.0.0.1,::1,localaddress,.localdomain
# BUILD_PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# BUILD_PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
# BUILD_GOPROXY=https://goproxy.cn,direct
