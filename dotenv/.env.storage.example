# Storage service and bucket settings
STORAGE_SERVICE_TOKEN=<replace-with-storage-service-token>
STORAGE_SERVICE_URL=http://storage-service:8090
STORAGE_SERVICE_TIMEOUT=30
IMAGE_FILE_BUCKET=medical-image-files
USER_AVATAR_BUCKET=medical-user-avatars

# For AI models running on host (non-Docker), set STORAGE_SERVICE_URL to the
# host-mapped port (requires ports: binding in storage-service.yml):
# STORAGE_SERVICE_URL=http://localhost:8090
