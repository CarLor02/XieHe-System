# Backend API settings
JWT_SECRET_KEY=<replace-with-a-long-random-jwt-secret>
FORWARDED_ALLOW_IPS=<replace-with-gpu1-private-ip-or-*>
BACKEND_CORS_ORIGINS=https://xiehe.example.com

# Backend-to-model object-mode AI endpoints. These are server-side only.
AI_AP_MEASUREMENT_OBJECT_URL=http://<ap-model-private-ip>:8001/api/measurement
AI_FRONT_KEYPOINTS_OBJECT_URL=http://<ap-model-private-ip>:8001/detect_keypoints_object
AI_LAT_MEASUREMENT_OBJECT_URL=http://<lat-model-private-ip>:8002/api/measurement
AI_LATERAL_DETECT_OBJECT_URL=http://<lat-model-private-ip>:8002/api/detect_object
